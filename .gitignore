# ============================================================
# Simulated Datasets
# Regenerate with: python -m data_collection.simulate_data
# ============================================================
ml/data/raw/simulated/**/*.csv
# Keep directory structure
!ml/data/raw/simulated/healthy/.gitkeep
!ml/data/raw/simulated/anomaly/.gitkeep

# ============================================================
# Hardware Datasets (collected from physical device)
# ============================================================
ml/data/raw/hardware/**/*.csv
# Keep directory structure
!ml/data/raw/hardware/healthy/.gitkeep
!ml/data/raw/hardware/clinical/.gitkeep

# Root-level raw capture files from receiver_logger.py
bra_raw_*.csv

# ============================================================
# Trained ML Models & Evaluation Artifacts
# Regenerated by: python -m ml.run_pipeline
# ============================================================
ml/models/

# ============================================================
# MLflow Experiment Tracking
# Generated by: python -m ml.run_pipeline --track
